{
  "version": 1,
  "agent": {
    "command": [
      "codex",
      "exec",
      "--full-auto",
      "--skip-git-repo-check",
      "--cd",
      "{project_root}",
      "--output-last-message",
      "{output_last_message}",
      "-"
    ],
    "review_command": [
      "codex",
      "exec",
      "-s",
      "read-only",
      "--skip-git-repo-check",
      "--cd",
      "{project_root}",
      "--output-last-message",
      "{output_last_message}",
      "-"
    ],
    "env": {},
    "timeout_seconds": {
      "seed": 180,
      "worker": 900,
      "review": 300,
      "evaluator": 300,
      "replan": 300
    },
    "heartbeat_seconds": 15
  },
  "loop": {
    "completion_promise": "COMPLETE",
    "max_iterations": 8,
    "mode": "implementation",
    "auto_seed_tasks": true,
    "require_intake_approval": true,
    "require_research_plan": true,
    "quality_profile": "",
    "workflow_profile": "",
    "workflow_stage": "",
    "workflow_goal": ""
  },
  "checks": {
    "commands": [],
    "stop_on_failure": true
  },
  "review": {
    "enabled": true,
    "max_findings": 5
  },
  "context": {
    "enabled": true,
    "refresh_each_iteration": true
  },
  "evaluator": {
    "enabled": true,
    "require_pass_for_completion": true,
    "auto_extend_tasks": true
  }
}
